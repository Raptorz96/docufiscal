# SQLite for local development
DATABASE_URL=sqlite:///./docufiscal.db

# PostgreSQL for Docker (uncomment and adjust for Docker usage)
# DATABASE_URL=postgresql://docufiscal:docufiscal@db:5432/docufiscal

# PostgreSQL Docker settings
POSTGRES_USER=docufiscal
POSTGRES_PASSWORD=docufiscal
POSTGRES_DB=docufiscal

# JWT Settings
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs
CLAUDE_API_KEY=your-claude-api-key-here